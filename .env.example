# VoidTools Bot Configuration
# Required for Replit deployment:
DISCORD_TOKEN=your_discord_bot_token
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/voidtools?retryWrites=true&w=majority

# Required if you want guild-scoped slash-command sync instead of global sync:
GUILD_ID=your_discord_guild_id

# Optional:
BOT_PREFIX=!
PORT=3000
HOST=0.0.0.0
GITHUB_TOKEN=
YOUTUBE_API_KEY=
DNS_SERVERS=

# Strongly recommended on a public deployment if you want to use the dashboard actions remotely:
DASHBOARD_TOKEN=choose_a_long_random_secret
